# Copy to .env for local Vercel dev or set these in Vercel project settings.

# Product Hunt API developer token.
# Required for live Product Hunt numbers through /api/badge and /api/readme-badge.
# Create one at: https://www.producthunt.com/v2/oauth/applications
PH_TOKEN=

# Optional: raises GitHub API rate limits from 60 to 5,000 requests/hour.
# For public repos, use a read-only fine-grained token with no extra scopes.
GITHUB_TOKEN=
